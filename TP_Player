-- Offset
local function getOffsetCFrame(hrp)
    local d = tonumber(distanceBox.Text) or 3

    if direction == "หน้า" then
        return hrp.CFrame * CFrame.new(0,0,-d)
    elseif direction == "หลัง" then
        return hrp.CFrame * CFrame.new(0,0,d)
    elseif direction == "ซ้าย" then
        return hrp.CFrame * CFrame.new(-d,0,0)
    elseif direction == "ขวา" then
        return hrp.CFrame * CFrame.new(d,0,0)
    elseif direction == "บน" then
        return hrp.CFrame * CFrame.new(0,d,0)
    elseif direction == "ล่าง" then
        return hrp.CFrame * CFrame.new(0,-d,0)
    end
end

-- TP
local function tp(plr)
    if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame =
            getOffsetCFrame(plr.Character.HumanoidRootPart)
    end
end

tpBtn.MouseButton1Click:Connect(function()
    tp(Players:FindFirstChild(textbox.Text))
end)

-- Follow
local following = false
followBtn.MouseButton1Click:Connect(function()
    following = not following
    followBtn.Text = "ตาม: " .. (following and "เปิด" or "ปิด")
end)

RunService.RenderStepped:Connect(function()
    if following then
        local t = Players:FindFirstChild(textbox.Text)
        if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame =
                getOffsetCFrame(t.Character.HumanoidRootPart)
        end
    end
end)

-- 👁 Spectate
local spectating = false

specBtn.MouseButton1Click:Connect(function()
    spectating = not spectating
    specBtn.Text = "ดู: " .. (spectating and "เปิด" or "ปิด")

    if not spectating then
        Camera.CameraSubject = LocalPlayer.Character
    end
end)

RunService.RenderStepped:Connect(function()
    if spectating then
        local t = Players:FindFirstChild(textbox.Text)
        if t and t.Character and t.Character:FindFirstChild("Humanoid") then
            Camera.CameraSubject = t.Character.Humanoid
        end
    end
end)

-- Load players
local function loadPlayers()
    for _,v in ipairs(scrolling:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,plr in ipairs(Players:GetPlayers()) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,0,0,25)
        btn.Text = plr.Name
        btn.TextScaled = true
        btn.Parent = scrolling
        rainbowText(btn)

        btn.MouseButton1Click:Connect(function()
            textbox.Text = plr.Name
        end)
    end

    task.wait(0.1)
    scrolling.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

Players.PlayerAdded:Connect(loadPlayers)
Players.PlayerRemoving:Connect(loadPlayers)

loadPlayers()
