-- 🌈 Rainbow
local function rainbowText(label)
    task.spawn(function()
        while label and label.Parent do
            for i = 0,1,0.01 do
                label.TextColor3 = Color3.fromHSV(i,1,1)
                task.wait()
            end
        end
    end)
end

